# OS-specific files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Backup files
*.bak
*.backup
*~

# Temporary files
*.tmp
*.temp

# Local machine-specific configs (if any)
local.conf
*.local
*.py[cod]

# Secrets and credentials
*.secret
.env
credentials
id_rsa
id_ed25519
*.pem
*.key
authorized_keys
known_hosts

# Claude Code — allowlist: ignore sensitive/ephemeral files, keep only config
claude/.claude/**
!claude/.claude/settings.json
!claude/.claude/CLAUDE.md
!claude/.claude/keybindings.json
!claude/.claude/statusline-command.sh

# Logs
*.log

# Stow backup directory
dotfiles_backup_*/

# Shell history files (if ever symlinked)
.bash_history
.zsh_history

# GPG
.gnupg/
